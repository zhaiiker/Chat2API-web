# Bind address. Use 0.0.0.0 to accept connections from outside the host.
HOST=0.0.0.0

# Port for the unified web UI + OpenAI-compatible proxy.
PORT=8080

# Strongly recommended in production: pin the Management API secret so it
# survives restarts. Generate one with `openssl rand -hex 32`.
# CHAT2API_MANAGEMENT_SECRET=

# Set to 1 to disable the Management API entirely (the web UI will not work).
# CHAT2API_DISABLE_MANAGEMENT_API=

# Pin the credential encryption key. Without this Chat2API auto-generates one
# and stores it under CHAT2API_DATA_DIR. If you replace your data volume, set
# this to keep encrypted credentials decryptable.
# CHAT2API_ENCRYPTION_KEY=

# Where to keep the persistent data file and logs. Defaults to ~/.chat2api
# CHAT2API_DATA_DIR=/var/lib/chat2api

# Override the directory the backend serves the built UI from.
# CHAT2API_FRONTEND_DIR=/app/dist/frontend


# Comma-separated list of allowed origins for the Management API (CORS).
# If unset, only same-origin (no Origin header) requests are allowed.
# Example: https://admin.example.com,http://localhost:3000
# CHAT2API_CORS_ORIGINS=
